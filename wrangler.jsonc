{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "imageboard",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-03-16",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "ff8b5539721547e1a61bebf836fc449c",
    }
  ]
}